    "Acute (7-day) vs chronic (28-day) training load. 0.8–1.3 is the sweet spot.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Acute (7-day) vs chronic (28-day) training load. 0.8–1.3 is the sweet spot."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Akute (7 Tage) vs. chronische (28 Tage) Trainingslast. 0,8–1,3 ist der ideale Bereich."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Соотношение острой (7-дневной) и хронической (28-дневной) тренировочной нагрузки. Оптимальный коэффициент , 0,8–1,3."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Charge d'entraînement aiguë (7 jours) vs chronique (28 jours). 0,8–1,3 est la zone idéale."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Carga de entrenamiento aguda (7 días) frente a crónica (28 días). 0,8–1,3 es el rango ideal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Carico di allenamento acuto (7 giorni) rispetto a cronico (28 giorni). 0,8–1,3 è la fascia ideale."
          }
        }
      }
    },
