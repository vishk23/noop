        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geschätzte maximale Herzfrequenz · %lld bpm"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расчётный макс. пульс · %lld уд/мин"
          }
        }
      }
    },
    "Every beat, every night, every day — woven into one quiet picture of you. Welcome to NOOP.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every beat, every night, every day — woven into one quiet picture of you. Welcome to NOOP."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeder Schlag, jede Nacht, jeder Tag — verwoben zu einem ruhigen Bild von dir. Willkommen bei NOOP."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждый удар сердца, каждая ночь, каждый день — всё складывается в цельную картину вашего состояния. Добро пожаловать в NOOP!"
          }
        }
      }
    },
    "Every session, threaded together.": {
      "localizations": {
