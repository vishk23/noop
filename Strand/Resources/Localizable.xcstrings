    "%@ is free and always will be. If it's useful to you, you can chip in to help with development and testing costs. Totally optional.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is free and always will be. If it's useful to you, you can chip in to help with development and testing costs. Totally optional."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ist kostenlos und bleibt es. Wenn es dir nützt, kannst du etwas zu den Entwicklungs- und Testkosten beitragen. Völlig freiwillig."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ бесплатен и всегда таким останется. Если он вам полезен, вы можете поддержать разработку и покрытие расходов на тестирование. Это полностью по желанию."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ est gratuit et le sera toujours. S'il vous est utile, vous pouvez contribuer aux coûts de développement et de test. Totalement facultatif."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ es gratis y siempre lo será. Si te resulta útil, puedes contribuir a los costos de desarrollo y pruebas. Totalmente opcional."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ è gratuito e lo sarà sempre. Se ti è utile, puoi contribuire ai costi di sviluppo e test. Del tutto facoltativo."
          }
        }
      }
    },
