          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Travail de rétro-ingénierie BLE open-source. Merci."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Trabajo de ingeniería inversa de BLE de código abierto. Gracias."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lavoro open-source di reverse engineering BLE. Grazie."
          }
        }
