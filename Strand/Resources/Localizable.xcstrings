    "These power your heart-rate zones, calorie estimates and recovery baselines. Keep them accurate.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These power your heart-rate zones, calorie estimates and recovery baselines. Keep them accurate."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese steuern deine Herzfrequenzzonen, Kalorienschätzungen und Erholungs-Basislinien. Halte sie genau."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На их основе рассчитываются пульсовые зоны, оценка калорий и личные нормы восстановления. Следите, чтобы данные были точными."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces éléments alimentent vos zones de fréquence cardiaque, estimations de calories et références de récupération. Gardez-les précis."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos alimentan tus zonas de frecuencia cardíaca, las estimaciones de calorías y las líneas base de recuperación. Mantenlos precisos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questi alimentano le tue zone di frequenza cardiaca, le stime caloriche e le linee di base del recupero. Mantienili accurati."
          }
        }
      }
    },
