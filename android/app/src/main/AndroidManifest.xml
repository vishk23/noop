<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      NOOP is an OFFLINE WHOOP companion. It talks to the strap over BLE and stores
      everything locally (Room). The ONLY outbound network is the opt-in AI Coach
      (bring-your-own OpenAI/Anthropic key) — nothing is sent unless the user adds a
      key and asks a question. Hence the single INTERNET permission below.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 12+ (API 31+) Bluetooth runtime permissions.
         neverForLocation: we do not derive physical location from BLE scans, so we
         can opt out of the location-permission requirement on API 31+. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="s" />
    <!-- Android 12+ (API 31+): broadcasting NOOP's live HR back out as a standard BLE Heart Rate
         peripheral (0x180D) so gym kit can read it needs the advertise permission. Opt-in only:
         the "Broadcast heart rate" toggle in Data Sources is OFF by default, and the permission is
         requested at runtime right before the broadcast starts (see rememberRequestAdvertise). -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADVERTISE"
        tools:targetApi="s" />

    <!-- Android 8-11 (API 26-30): legacy Bluetooth perms are install-time. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Fine location is needed on ALL API levels: pre-12 (API <=30) for BLE scans, and on every
         version for GPS-tracked workouts (route/distance/pace). It is requested at runtime right
         before a GPS workout starts (see rememberRequestLocation, #101) — NOT for BLE, which stays
         opted out of location via neverForLocation above. Capping this at API 30 made GPS workouts
         crash on Android 12+ because the permission could never be held. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Keep the BLE link alive while collecting/offloading in the background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:targetApi="34" />
    <!-- GPS-tracked workouts: the connection service keeps tracking the route while backgrounded. -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_LOCATION"
        tools:targetApi="34" />

    <!-- Android 13+ (API 33+): the ongoing "strap connected" notification is user-dismissable and
         must be granted at runtime. Requested in MainActivity alongside the BLE permissions. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Optional call alerts. Requested only when the user enables "Phone calls"; NOOP does not
         request READ_CALL_LOG and never reads incoming numbers, contacts, or call history. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Smart alarm (#207). The guaranteed wake is an exact OS alarm scheduled via AlarmManager,
         independent of Bluetooth and the app being alive. SCHEDULE_EXACT_ALARM (API 31-32) is
         requested at runtime from the alarm screen; USE_EXACT_ALARM (API 33+) is the alarm-clock
         use-case grant the Play policy allows for a genuine user-set wake alarm. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Re-arm the guaranteed alarm after a reboot so an overnight restart can't silently drop it. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Promote the fired alarm to a true full-screen wake on a locked screen (Android 14+ gates the
         full-screen-intent path behind this; CATEGORY_ALARM is an allowed use. Without it the alarm
         still sounds as a high-priority heads-up, but the lock-screen takeover is downgraded). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- BLE is mandatory hardware for this app. -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <!-- Health Connect (optional): read-only access to the user's own health data so it can
         be imported on-device. Nothing is uploaded. Granted at runtime, revocable any time. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <!-- Health Connect writeback (optional, opt-in, default OFF): lets NOOP contribute its
         on-device computed nightly metrics so other apps can read them. Only what NOOP itself
         computed from the strap is written — imported data is never echoed back. -->
    <uses-permission android:name="android.permission.health.WRITE_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.WRITE_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.WRITE_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.WRITE_RESPIRATORY_RATE" />
    <!-- HR samples, steps, active energy, and sleep writeback (#528, opt-in, default OFF). -->
    <uses-permission android:name="android.permission.health.WRITE_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.WRITE_STEPS" />
    <uses-permission android:name="android.permission.health.WRITE_HEART_RATE" />
    <uses-permission android:name="android.permission.health.WRITE_SLEEP" />
    <!-- Exercise-session + distance writeback (GPS workouts, opt-in). MUST be declared or Health
         Connect silently drops the runtime request and live workouts never write back (#412). -->
    <uses-permission android:name="android.permission.health.WRITE_EXERCISE" />
    <uses-permission android:name="android.permission.health.WRITE_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_VO2_MAX" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" />
    <uses-permission android:name="android.permission.health.READ_LEAN_BODY_MASS" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />

    <!-- Resolve the Health Connect provider on Android 14+ (platform) and earlier (app). -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <!-- So the connection helper can detect the official WHOOP app and deep-link to its
             info screen (a strap only pairs with one app at a time). Android 11+ visibility. -->
        <package android:name="com.whoop.android" />
    </queries>

    <application
        android:name=".NoopApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NOOP"
        tools:targetApi="34">

        <!--
          MainActivity no longer carries the LAUNCHER intent-filter itself. The home-screen entry
          point is split into two <activity-alias> elements below (.IconDefault / .IconNavy), each
          carrying the LAUNCHER filter and a different launcher icon. Settings → "App Icon" enables
          exactly one alias at runtime via PackageManager.setComponentEnabledSetting, which is what
          lets the user swap the machined-titanium and blued-titanium icons without a reinstall. The
          activity stays exported so the enabled alias can target it. (#v3-titanium-gold)
        -->
        <activity
            android:name="com.noop.ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.NOOP">
            <!-- Health Connect permissions-rationale route for Android 13 and below (#226). The standalone
                 Health Connect APK on API ≤33 DISCOVERS + lists compatible apps by this intent-filter, so
                 the action name must be the legacy `androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE`.
                 The previous `androidx.health.connect.action.SHOW_PERMISSIONS_RATIONALE` is neither the
                 API-33 nor API-34 form, so an Android-13 HC APK never enumerated NOOP — it was absent from
                 Health Connect's "App permissions" entirely and permissions couldn't be granted. Android 14+
                 (HC in the platform) uses the `ViewPermissionUsageActivity` alias below instead. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!--
          Launcher icon aliases. Exactly one is ever enabled (see SettingsScreen "App Icon"):
            .IconDefault — machined-titanium icon (@mipmap/ic_launcher), enabled by default.
            .IconNavy    — blued/dark-blue titanium icon (@mipmap/ic_launcher_navy), disabled.
          Both target MainActivity and carry the MAIN/LAUNCHER filter, so whichever is enabled is the
          one home-screen entry point. Toggling them is what re-paints the launcher icon at runtime.
        -->
        <activity-alias
            android:name="com.noop.IconDefault"
            android:targetActivity="com.noop.ui.MainActivity"
            android:exported="true"
            android:enabled="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name="com.noop.IconNavy"
            android:targetActivity="com.noop.ui.MainActivity"
            android:exported="true"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher_navy"
            android:roundIcon="@mipmap/ic_launcher_navy"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Health Connect permissions-rationale route (Android 14+, platform Health Connect). -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity="com.noop.ui.MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Keeps the WHOOP connection alive while the app is backgrounded or closed. Not exported;
             started/stopped only from within the app, gated by the "Keep connected in the
             background" Settings toggle. -->
        <service
            android:name="com.noop.ble.WhoopConnectionService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice|location" />

        <!-- Wrist alerts: this is what makes NOOP appear in Android's Notification Access list. The
             system binds it (guarded by BIND_NOTIFICATION_LISTENER_SERVICE) only after the user grants
             access; it reads which app posted a notification — never the content — to buzz the strap,
             gated by the Notifications-screen settings. Does nothing until access is granted + enabled. -->
        <service
            android:name="com.noop.notif.NoopNotificationListener"
            android:label="NOOP wrist alerts"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Home-screen widget (today's recovery + live HR + strap battery). exported=true is
             required so the launcher can deliver APPWIDGET_UPDATE; it renders only from our own
             SharedPreferences snapshot. -->
        <receiver
            android:name="com.noop.widget.NoopWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/noop_widget_info" />
        </receiver>

        <!-- Optional native phone-call alerts. The receiver only reacts to ringing/offhook/idle state
             and never reads the incoming-number extra. Delivery is gated by the Notifications screen
             settings and by the just-in-time READ_PHONE_STATE runtime permission. -->
        <receiver
            android:name="com.noop.notif.PhoneCallReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Smart alarm (#207): the guaranteed wake. AlarmManager fires this receiver at the latest
             edge of the window (or earlier if the light-sleep watcher advanced it); it raises a
             full-screen alarm notification with sound + vibration. Not exported — only our own
             PendingIntent triggers it — but it survives the app being killed so the wake is reliable. -->
        <receiver
            android:name="com.noop.alarm.SmartAlarmReceiver"
            android:exported="false" />

        <!-- Re-arms the persisted hard-deadline alarm after a reboot so an overnight restart can't
             silently drop the user's wake. -->
        <receiver
            android:name="com.noop.alarm.SmartAlarmBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Wind-down nudge (non-critical): the daily evening reminder fires this receiver, which
             raises a low-key notification. Not exported. -->
        <receiver
            android:name="com.noop.alarm.WindDownReceiver"
            android:exported="false" />

        <!-- Shares the strap log (a cache file) for bug reports. Not exported; read access is granted
             per-share via FLAG_GRANT_READ_URI_PERMISSION. Authority is applicationId-scoped so the
             full + demo flavors don't collide. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
